{
  "manifest_version": 3,
  "name": "Gipalti",
  "version": "1.0",
  "description": "Read payerToken from Tipalti Hub",
  "permissions": ["cookies", "tabs"],
  "host_permissions": [
    "https://hub.tipalti.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
        "matches": ["https://hub.tipalti.com/*"],
        "js": ["content.js"],
        "css": ["content.css"]
    },
    {
      "matches": ["https://*.approve.com/dashboard/purchase-request/request/*"],
      "js": ["ep.js"]
    }
  ]
}
